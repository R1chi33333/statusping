# Bearer token for the admin UI and write API. Required in production.
ADMIN_TOKEN=

# Where the SQLite database lives. The Docker image mounts /app/data.
DATABASE_PATH=./data/statusping.db

# Port the server listens on.
PORT=3000

# Slug of the public status page, e.g. "status" serves /status/status
STATUS_SLUG=status

# Webhooks for down and recovery alerts (both optional)
WEBHOOK_DISCORD_URL=
WEBHOOK_SLACK_URL=
